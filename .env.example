# =============================
# SkyBooker Production .env
# =============================
# Place this file as .env on EC2 beside docker-compose.prod.yml
# and replace placeholders with real values.

# -----------------------------------------------------------------
# Frontend <-> API gateway routing (MANDATORY)
# -----------------------------------------------------------------
# Browser API target used by frontend runtime env injection.
FRONTEND_API_BASE_URL=http://52.91.177.84:8080

# CORS allowed origin in api-gateway (must match frontend origin exactly).
CORS_ALLOWED_ORIGIN=http://52.91.177.84

# -----------------------------------------------------------------
# Auth/JWT/Google OAuth
# -----------------------------------------------------------------
# MANDATORY in production: use a long random base64 secret.
JWT_SECRET=replace_with_long_random_base64_secret

# Required only if Google login/signup is enabled.
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id

# Optional
PASSWORD_RESET_EXPIRY_MINUTES=15

# -----------------------------------------------------------------
# MySQL (containers + services)
# -----------------------------------------------------------------
# Keep aligned with docker-compose.prod.yml defaults.
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=root
MYSQL_PASSWORD=root

# -----------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------
# Payment
# -----------------------------------------------------------------
# MANDATORY if online payment flow is used.
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_API_BASE_URL=https://api.razorpay.com

# -----------------------------------------------------------------
# Mail/Notification
# -----------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_mail_username
MAIL_PASSWORD=replace_with_mail_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
NOTIFICATION_EMAIL_FROM=noreply@yourdomain.com
NOTIFICATION_EMAIL_FALLBACK_DOMAIN=yourdomain.com

# -----------------------------------------------------------------
# Optional event tuning
# -----------------------------------------------------------------
BOOKING_EVENT_EXCHANGE=skybooker.events
NOTIFICATION_EVENT_EXCHANGE=skybooker.events

# -----------------------------------------------------------------
# Compose project name
# -----------------------------------------------------------------
# Keep this as skybooker so existing Docker volumes are reused.
COMPOSE_PROJECT_NAME=skybooker

# Flight seed switch (true recommended for new empty deployments)
APP_SEED_DATA=true
